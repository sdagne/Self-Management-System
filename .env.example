# ============================================================
# Queue Management System — Environment Variables  
# Copy this file to .env and fill in ALL values before running.
# NEVER commit the real .env file to version control.
# ============================================================

# ---- Application -----------------------------------------------
APP_ENV=development        # development | production
LOG_LEVEL=info            # debug | info | warning | error

# ---- Database --------------------------------------------------
# Development: SQLite (default, no extra setup)
DATABASE_URL=sqlite:///./queue_management.db
# Production: PostgreSQL (recommended)
# DATABASE_URL=postgresql://queueuser:STRONG_PASSWORD@localhost:5432/queue_management

# ---- Redis (Cache & Message Broker) ---------------------------
# Optional: Application works without Redis (with degraded performance)
# Development: local Redis
REDIS_URL=redis://localhost:6379/0
# Production: Redis cluster or managed service
# REDIS_URL=redis://redis-cluster.example.com:6379/0

# ---- Celery (Async Task Queue) --------------------------------
# Only required if using async tasks (Telegram notifications, reminders)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Security --------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- API Tokens (static, for hardware kiosks / counters) -------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN
COUNTER_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN
DISPLAY_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# ---- CORS (comma-separated list of allowed origins) -----------
# Development: localhost
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001
# Production: your real domain(s)
# CORS_ORIGINS=https://queue.yourdomain.com

# ---- Rate Limiting --------------------------------------------
RATE_LIMIT_TICKETS=10/minute
RATE_LIMIT_DEFAULT=60/minute

# ---- Ticket Configuration ------------------------------------
TICKET_EXPIRY_HOURS=2
MAX_QUEUE_SIZE=500

# ---- Server --------------------------------------------------
HOST=0.0.0.0
PORT=8001

# ---- Telegram Integration (optional) ------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=False
